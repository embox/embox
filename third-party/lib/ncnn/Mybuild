package third_party.lib.ncnn


@BuildArtifactPath(
  cppflags="-I$(EXTERNAL_BUILD_DIR)/third_party/lib/ncnn/libncnn/install/include/ncnn"
)
module ncnn_public_headers {}

@Build(stage=1, script="$(EXTERNAL_MAKE)")
@BuildDepends(third_party.lib.ncnn.ncnn_public_headers)
@BuildDepends(third_party.compiler_headers)
@BuildDepends(embox.cxx.LibCxx)
static module libncnn {

    source
        "^BUILD/extbld/third_party/lib/ncnn/libncnn/install/lib/libncnn.a",
        "ncnn_new_delete.cpp",
        "ncnn_math_trig_shim.cpp"

    depends third_party.lib.ncnn.ncnn_public_headers
    depends third_party.compiler_headers
    depends embox.cxx.LibCxx
}