package embox.driver.can

module mcp2515 {
	option string log_level="LOG_WARNING"

	option number dev_id=0

	option boolean sleep_mode=false
	option boolean loopback_mode=false

	option number spi_bus=1
	option number spi_cs=0

	option number gpio_irq_port=0xff
	option number gpio_irq_pin=0

	option number propseg=1
	option number phseg1=3
	option number phseg2=3
	option number bitrate=500000
	option number clk_freq=8000000

	source "mcp2515.c"

	depends embox.driver.spi.core
	@NoRuntime depends embox.device.can_dev
	@NoRuntime depends embox.driver.gpio.core
}
